FROM ubuntu:jammy
ARG DGT_TOP
#RUN apt-get update && apt-get install gnupg -y

# git python3-stdeb net-tools pkg-config
RUN apt-get update && apt-get install --no-install-recommends -y -q \
    iputils-ping \
    unzip         \
    openssl

RUN apt-get install --no-install-recommends -y -q \
    python3       \
    python3-pip   \
    python3-grpcio \
    python3-protobuf
    

RUN apt-get install --no-install-recommends -y -q \
    python3-cbor \
    python3-colorlog \
    python3-cryptography>=1.7.1 \
    python3-dev \
    python3-lmdb \
    python3-netifaces \
    python3-toml \
    python3-yaml \
    python3-zmq \
    python3-requests \
    python3-sha3 \
    && rm -rf /var/lib/apt/lists/*
     
      
#  python3-graphviz libssl-dev
RUN pip3 install secp256k1
RUN pip3 install grpcio-tools
RUN pip3 install pyformance
RUN pip3 install chardet
RUN pip3 install cookiecutter
RUN pip3 install fastapi
RUN pip3 install pydantic pydantic-settings
RUN pip3 install sqlalchemy
RUN pip3 install sqlalchemy_utils
RUN pip3 install jwt
RUN pip3 install alembic
RUN pip3 install uvicorn
RUN pip3 install common
RUN pip3 install email-validator
RUN pip3 install environs
RUN pip3 install influxdb
RUN pip3 install influxdb_client
#RUN pip3 install asyncpg # postgress
RUN pip3 install passlib
RUN pip3 install slowapi
RUN pip3 install aiosqlite
RUN pip3 install python-multipart
